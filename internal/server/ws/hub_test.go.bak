package ws

import (
	"testing"
	"time"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestNewHub(t *testing.T) {
	hub := NewHub()

	assert.NotNil(t, hub)
	assert.NotNil(t, hub.clients)
	assert.NotNil(t, hub.userClients)
	assert.NotNil(t, hub.broadcast)
	assert.NotNil(t, hub.register)
	assert.NotNil(t, hub.unregister)
	assert.NotNil(t, hub.errorChan)
	assert.NotNil(t, hub.ctx)
	assert.NotNil(t, hub.cancel)
	assert.False(t, hub.IsClosed())
}

func TestHubRun(t *testing.T) {
	hub := NewHub()

	done := make(chan struct{})
	go func() {
		hub.Run()
		close(done)
	}()

	client := NewClient(hub, nil, "user-1")
	hub.Register(client)

	select {
	case <-done:
		t.Fatal("hub should not stop immediately")
	default:
	}

	hub.Stop()

	select {
	case <-done:
	case <-time.After(1 * time.Second):
		t.Fatal("hub did not stop")
	}

	assert.True(t, hub.IsClosed())
}

func TestHubRegister(t *testing.T) {
	hub := NewHub()
	go hub.Run()

	client := NewClient(hub, nil, "user-1")
	hub.Register(client)

	time.Sleep(50 * time.Millisecond)

	assert.Equal(t, 1, hub.ClientCount())
	assert.Equal(t, 1, hub.UserCount())

	registeredClient, err := hub.GetClient(client.ID())
	assert.NoError(t, err)
	assert.Equal(t, client.ID(), registeredClient.ID())

	hub.Stop()
}

func TestHubUnregister(t *testing.T) {
	hub := NewHub()
	go hub.Run()

	client := NewClient(hub, nil, "user-1")
	hub.Register(client)

	time.Sleep(50 * time.Millisecond)
	assert.Equal(t, 1, hub.ClientCount())

	hub.Unregister(client)

	time.Sleep(50 * time.Millisecond)
	assert.Equal(t, 0, hub.ClientCount())
	assert.Equal(t, 0, hub.UserCount())

	hub.Stop()
}

func TestHubGetClient(t *testing.T) {
	hub := NewHub()

	client := NewClient(hub, nil, "user-1")
	hub.Register(client)

	time.Sleep(50 * time.Millisecond)

	retrievedClient, err := hub.GetClient(client.ID())
	assert.NoError(t, err)
	assert.Equal(t, client.ID(), retrievedClient.ID())

	_, err = hub.GetClient("non-existent")
	assert.Error(t, err)
	assert.Equal(t, ErrClientNotFound, err)
}

func TestHubGetClientsByUser(t *testing.T) {
	hub := NewHub()

	client1 := NewClient(hub, nil, "user-1")
	client2 := NewClient(hub, nil, "user-1")
	client3 := NewClient(hub, nil, "user-2")

	hub.Register(client1)
	hub.Register(client2)
	hub.Register(client3)

	time.Sleep(50 * time.Millisecond)

	user1Clients := hub.GetClientsByUser("user-1")
	assert.Len(t, user1Clients, 2)

	user2Clients := hub.GetClientsByUser("user-2")
	assert.Len(t, user2Clients, 1)

	nonexistentClients := hub.GetClientsByUser("user-3")
	assert.Len(t, nonexistentClients, 0)
}

