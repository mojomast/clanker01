func TestHubClientCount(t *testing.T) {
	hub := NewHub()

	assert.Equal(t, 0, hub.ClientCount())

	client := NewClient(hub, nil, "user-1")
	hub.Register(client)

	time.Sleep(50 * time.Millisecond)
	assert.Equal(t, 1, hub.ClientCount())
}

func TestHubUserCount(t *testing.T) {
	hub := NewHub()

	assert.Equal(t, 0, hub.UserCount())

	client1 := NewClient(hub, nil, "user-1")
	client2 := NewClient(hub, nil, "user-1")
	client3 := NewClient(hub, nil, "user-2")

	hub.Register(client1)
	hub.Register(client2)
	hub.Register(client3)

	time.Sleep(50 * time.Millisecond)
	assert.Equal(t, 2, hub.UserCount())
}

func TestHubBroadcastAll(t *testing.T) {
	hub := NewHub()

	client1 := NewClient(hub, nil, "user-1")
	client2 := NewClient(hub, nil, "user-2")

	hub.Register(client1)
	hub.Register(client2)

	time.Sleep(50 * time.Millisecond)

	msg := NewLogEntry("info", "test message", "agent-1", "task-1")
	err := hub.BroadcastAll(msg)
	assert.NoError(t, err)

	time.Sleep(50 * time.Millisecond)

	select {
	case <-client1.send:
	case <-time.After(100 * time.Millisecond):
		t.Fatal("client1 did not receive message")
	}

	select {
	case <-client2.send:
	case <-time.After(100 * time.Millisecond):
		t.Fatal("client2 did not receive message")
	}
}

