func TestHubBroadcastWithSubscription(t *testing.T) {
	hub := NewHub()

	client1 := NewClient(hub, nil, "user-1")
	client1.sub.AddMessageType(MessageTypeLog)

	client2 := NewClient(hub, nil, "user-2")
	client2.sub.AddMessageType(MessageTypeError)

	hub.Register(client1)
	hub.Register(client2)

	time.Sleep(50 * time.Millisecond)

	logMsg := NewLogEntry("info", "test message", "agent-1", "task-1")
	err := hub.BroadcastAll(logMsg)
	require.NoError(t, err)

	time.Sleep(50 * time.Millisecond)

	select {
	case <-client1.send:
	case <-time.After(100 * time.Millisecond):
		t.Fatal("client1 did not receive log message")
	}

	select {
	case <-client2.send:
		t.Fatal("client2 should not receive log message")
	case <-time.After(50 * time.Millisecond):
	}
}
